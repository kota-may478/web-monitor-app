# ===================================================
# Web Monitor App - 環境変数設定
# このファイルをコピーして .env を作成し、値を入力してください
# .env は絶対にgitにコミットしないこと
# ===================================================

# Google AI Studio APIキー
# 取得先: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token（Secretsの読み書きにはfine-grainedトークン不可、classic必須）
# 必要スコープ: repo（全て）+ workflow
# 取得先: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# GitHubリポジトリ（owner/repo 形式）
# 例: kota-may478/web-monitor-app
GITHUB_REPO=your_username/web-monitor-app

# Resend APIキー
# 取得先: https://resend.com（サインアップ後のオンボーディング画面で自動表示）
RESEND_API_KEY=your_resend_api_key_here

# 送信元メールアドレス（Resendで確認済みのドメインのアドレス）
# 初期テスト時は onboarding@resend.dev を使用可
RESEND_FROM_EMAIL=onboarding@resend.dev

# CORS設定（フロントエンドのオリジン）
FRONTEND_URL=http://localhost:5173

# フロントエンドからバックエンドを呼び出すURL
VITE_API_BASE_URL=http://localhost:8000

# API認証（オプション。ローカルでは未設定のままで可）
# 有効にする場合: 以下2つに同じ値を設定すること（片方だけだと401エラー）
# 無効にする場合: 両方とも空欄のまま
# 生成方法: openssl rand -hex 32
API_KEY=

# フロントエンド用（API_KEY と同じ値）
VITE_API_KEY=
