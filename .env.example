# ===================================================
# Web Monitor App - 環境変数設定
# このファイルをコピーして .env を作成し、値を入力してください
# .env は絶対にgitにコミットしないこと
# ===================================================

# Google AI Studio APIキー
# 取得先: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token（Secretsの読み書きにはfine-grainedトークン不可、classic必須）
# 必要スコープ: repo（全て）
# 取得先: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# GitHubリポジトリ（owner/repo 形式）
# 例: kotaroikeda/web-monitor-app
GITHUB_REPO=your_username/web-monitor-app

# Resend APIキー
# 取得先: https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# 送信元メールアドレス（Resendで確認済みのドメインのアドレス）
# 初期テスト時は onboarding@resend.dev を使用可
RESEND_FROM_EMAIL=onboarding@resend.dev

# CORS設定（フロントエンドのオリジン）
FRONTEND_URL=http://localhost:5173

# フロントエンドからバックエンドを呼び出すURL
VITE_API_BASE_URL=http://localhost:8000
